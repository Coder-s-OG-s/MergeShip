# ---------------------------------------------------------------------------
# Appwrite — Client-side (exposed to the browser, safe to be public)
# ---------------------------------------------------------------------------
# Appwrite Cloud endpoint. Change to your self-hosted URL if applicable.
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1

# Found in Appwrite Console → your project → Settings → Project ID
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id

# ---------------------------------------------------------------------------
# Appwrite — Server-side (never exposed to the browser)
# ---------------------------------------------------------------------------
APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
APPWRITE_PROJECT_ID=your_project_id

# Found in Appwrite Console → your project → Overview → Integrations → API Keys
# Required scopes: account (read/write), sessions (delete)
APPWRITE_API_KEY=your_server_api_key

# ---------------------------------------------------------------------------
# Groq — AI-powered learning path generation (server-side only)
# ---------------------------------------------------------------------------
# Create a free API key at https://console.groq.com
GROQ_API_KEY=your_groq_api_key

# ---------------------------------------------------------------------------
# GitHub OAuth setup (configured inside Appwrite Console, not here)
# ---------------------------------------------------------------------------
# MergeShip uses Appwrite as the OAuth broker — GitHub credentials are entered
# in Appwrite Console and never stored in this application.
#
# Steps to enable GitHub login:
#   1. Go to https://github.com/settings/developers → OAuth Apps → New OAuth App
#   2. Set "Authorization callback URL" to:
#        https://<your-appwrite-endpoint>/v1/account/sessions/oauth2/callback/github/<your_project_id>
#      For Appwrite Cloud: https://sgp.cloud.appwrite.io/v1/account/sessions/oauth2/callback/github/<your_project_id>
#   3. Copy the Client ID and Client Secret.
#   4. In Appwrite Console → Auth → OAuth2 Providers → GitHub → enable and paste the credentials.
#
# OAuth security notes:
#   - OAuth state parameter (CSRF protection) is handled automatically by Appwrite.
#   - No GitHub tokens are logged or stored in this application.
#   - Minimum OAuth scope requested: read:user
