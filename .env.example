# Supabase
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# GitHub App (mandatory install gate)
GITHUB_APP_ID=
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_SLUG=mergeship
GITHUB_WEBHOOK_SECRET=

# Redis (Official Redis for Vercel / Upstash compatible)
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# Inngest
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Groq (LLM)
GROQ_API_KEY=
GROQ_BUDGET_PER_DAY=400000

# Observability
SENTRY_DSN=
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# Local-only flags (defaults: mock everything so contributors don't need real keys)
MOCK_GITHUB_API=true
MOCK_GITHUB_WEBHOOKS=true
MOCK_LLM=true

# Public app URL (for OAuth callback)
NEXT_PUBLIC_APP_URL=http://localhost:3000
